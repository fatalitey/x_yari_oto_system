# --- Genel (yerel cihaz) ---
# SQLite varsayılan olarak ./data/app.db — bu makinede kalır; cihaz değişince sıfırdan başlarsınız.
NODE_ID=node-a
# Ortak veritabanı + birden fazla süreç aynı makinede: true. Tek PC tek süreç: false
LEADER_ELECTION_ENABLED=false
LEADER_LEASE_SECONDS=600
STANDALONE_APPROVAL_BOT=false
APPROVAL_BOT_ENABLED=true

DATABASE_URL=sqlite:///./data/app.db
MEDIA_STORAGE_ROOT=storage/media
# Medya dosyaları bu süreden eskiyse günlük temizlikte silinir.
MEDIA_RETENTION_HOURS=24
# Yayın kapalı testte onay sonrası üretilecek taslak dosyaları burada tutulur.
DRAFT_EXPORT_ROOT=storage/x_drafts

# --- Zamanlama ---
# true: süreç açılışında ilk tur + sonra her 2 saatte bir kanal çekimi ve onay gönderimi. false: FETCH_INTERVAL_MINUTES ile aralık
FETCH_ON_THE_HOUR=true
FETCH_INTERVAL_MINUTES=120
# Uygulama açılır açılmaz bir fetch+dispatch turu koştur.
RUN_INITIAL_FETCH_DISPATCH=true
# Her 2 saatlik dispatch turunda kaynak kanal başına üst sınır.
DISPATCH_MAX_PER_CHANNEL=3
SCHEDULER_TIMEZONE=Europe/Istanbul
# false: X'e yayın job'u kapanır; onay sonrası sadece GPT önizleme üretir.
PUBLISH_ENABLED=true
PUBLISH_INTERVAL_MINUTES=30

# Havuz: son alımdan (fetched_at) bu kadar saat geçen kayıt tamamen silinir
POOL_MAX_FETCHED_AGE_HOURS=2
# Mesaj yaşı penceresi (onaya gönderimde son 2 saatten top 5 seçilir)
POST_MAX_AGE_HOURS=2
# Sadece temizlikte düşük etkileşimli eski kayıtları kırpmak için kullanılır.
POST_MIN_REACTIONS=100

# Eski terminal kayıtlar / tamamlanmış kuyruk satırları için üst sınır (saat)
CLEANUP_RETENTION_HOURS=24
NEAR_DUPLICATE_SIMILARITY=0.92

# --- Telethon (kanalları okumak = kullanıcı hesabı oturumu) ---
# TELEGRAM_API_ID / TELEGRAM_API_HASH: https://my.telegram.org → "API development tools"
# TELEGRAM_SESSION_STRING: bir kerelik giriş sonrası string; scripts/export_telegram_string_session.py
# TELEGRAM_MONITOR_CHATS: @kanaladı veya sayısal sohbet id (virgülle). Sayısal id için kanala
#   üyeyken @RawDataBot veya benzeri botlardan / mesaj bağlantısından -100... biçimini kopyalayın.
# TELEGRAM_FETCH_LIMIT: kanal başına son kaç mesaj taranır (10–500, varsayılan 100)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_MONITOR_CHATS=-1001234567890,@ornekkanal
TELEGRAM_FETCH_LIMIT=100

# --- Onay botu (Bot API; ayrı bir "bot" hesabı) ---
# TELEGRAM_BOT_TOKEN: @BotFather → /token
# TELEGRAM_APPROVAL_CHAT_ID (veya eski adı TELEGRAM_ADMIN_USER_ID):
#   Tek kişi: kendi kullanıcı id'niz (pozitif), @userinfobot ile.
#   İki kişi: ortak grup/süper grup açın, bota ekleyin, grubun id'sini yazın (-100...).
#   Grup üyeleri aday mesajını ve Onayla/Reddet düğmelerini birlikte görür.
#   Yayın kuyruğu (yalnız bu sohbette): /sira listeler; /sira 6 cikar 6. sıradakini çıkarır.
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVAL_CHAT_ID=

# --- OpenAI (X metni + Telegram TR önizleme çevirisi) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- X ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

LOG_LEVEL=INFO
